<!--pages/signboard/signboard.wxml-->
<navigation-bar title="指示牌"></navigation-bar>
<!-- 设备管理页 -->


<!-- 设备列表 -->
<scroll-view class="device-list" scroll-y>
  <view 
    class="device-item"
    wx:for="{{signboardList}}"
    wx:key="id"
    bindtap="viewDetail"
    data-id="{{item.id}}"
  >
    <view class="device-info">
      <view class="device-header">
        <text class="device-mac">{{item.mac_address}}</text>
        <view class="device-status online">在线</view>
      </view>
      
      <view class="device-details">
        <view class="detail-row">
          <text class="detail-label">方向:</text>
          <text class="detail-value">{{item.display}}</text>
        </view>
        <view class="detail-row">
          <text class="detail-label">亮度:</text>
          <text class="detail-value">{{item.brightness}}%</text>
        </view>
        <view class="detail-row">
          <text class="detail-label">占空比:</text>
          <text class="detail-value">{{item.duty_cycle}}</text>
        </view>
      </view>

      <view class="device-address">
        <t-icon name="location" size="32rpx" class="address-icon" />
        <text class="address-text">{{item.address}}</text>
      </view>
    </view>

    <view class="device-actions" catchtap="">
      <view class="action-btn delete-btn" bindtap="deleteDevice" data-id="{{item.id}}" data-name="{{item.mac_address}}">
        <text>删除</text>
      </view>
    </view>
  </view>


  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && signboardList.length === 0}}">
    <t-icon name="inbox" size="96rpx" class="empty-icon" />
    <text class="empty-text">暂无设备</text>
    <text class="empty-tip">点击下方按钮添加设备</text>
  </view>
</scroll-view>

<!-- 添加按钮 -->
<view class="add-btn" bindtap="addDevice">
  <text>+ 添加设备</text>
</view>

<!-- 加载提示 -->
<view class="loading-mask" wx:if="{{loading}}">
  <view class="loading-spinner"></view>
</view>

