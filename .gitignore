# ===================== 系统文件忽略 =====================
# macOS 系统文件
.DS_Store
.Spotlight-V100/
.fseventsd/
.Trashes/
._*

# Windows 系统文件
Thumbs.db
Desktop.ini
ehthumbs.db
*.tmp
*.log

# ===================== 项目依赖与构建产物 =====================
# Node.js 依赖（所有子项目的 node_modules 都会被忽略）
node_modules/

# 构建输出目录
dist/
build/
output/

# ===================== 编辑器与IDE配置 =====================
.vscode/
.idea/
*.iml
*.swp
*.swo

