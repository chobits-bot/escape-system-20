/* pages/Users/Users.wxss */
page{background-color:#eee;
    
height: 100%;}
.usersmain{
    width: 100%;
    height: 280rpx;
    /* background-image: linear-gradient(62deg, #8EC5FC 0%, #E0C3FC 100%); */
    
}
.userhand{
    padding-top: 50rpx;
    text-align: center;
}
.username{
    padding-top: 30rpx;
    text-align: center;
    font-size: 40rpx;
    
}
.userimg{
    width: 120rpx;
    height: 120rpx;
    border-radius: 50%;
    border: royalblue solid 2rpx;
    text-align: center;
    align-items: center;
    border-left: 500rpx;
}

/* 基础服务 */

.function{
    justify-content: center;
    display: flex;
    align-items: center;
}
.functiontitle{
    padding-top: 22rpx;
}
.mainfunction{
    background-color: #ffffff;
    border-radius: 30rpx;
    width: 700rpx;
    height: 200rpx;
}
  .outside{
    display: flex;
    /* align-items: center; */
    justify-content: center;
  }
  .inside{
    display: flex;
    flex-direction: column;
    text-align: center;
  }
  .ima{
      margin: 15rpx  50rpx;
      width: 50rpx;
      height: 50rpx;
  }
  .imatext{
      font-size: 22rpx;
  }
/* 更多服务 */
.other{
    padding-top: 20rpx;
    justify-content: center;
    display: flex;
    align-items: center;
}
.mainother{
    background-color: #ffffff;
    border-radius: 30rpx;
    width: 700rpx;
    height: 700rpx;
}
/* 包裹盒子的盒子 */
.otherbox{
    display: flex;
    flex-direction: column;
    margin-left: 40rpx;
    margin-top: 20rpx;

}
/* 内容盒子 */
.boxContent{
    display: flex;
    margin-left: 7rpx;
    margin-top: 38rpx;
    
}
/* 文字 */
.othertext{
    font-size: 35rpx;
    margin-left: 15rpx;
}
/* 第一图片 */
.otheriam{
    width: 45rpx;
    height: 45rpx;
    
}
/* 第二图片 */
.otherima{
    width: 45rpx;
    height: 45rpx;
    margin-left: 400rpx;
    
}

  





