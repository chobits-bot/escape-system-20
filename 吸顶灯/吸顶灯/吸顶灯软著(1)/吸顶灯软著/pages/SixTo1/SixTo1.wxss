/* 宽度度 */
.weight{
  display:flex;
  flex-direction:column;
  width: 700rpx;
  justify-content: center;
}

.insideweight{
  display:flex;
  flex-direction:column;
  width: 650rpx;
  justify-content: center;
}

/* 顶部设计 */
.top{
  width: 100%;
  height: 200px;
  background: linear-gradient(121deg, #94C7FE -1%, #1890FF 102%);
  box-shadow: 24px 52px 100px 0px rgba(90, 108, 234, )
}

.head_top{
  width: 100%;
  height: 100rpx;
  position: relative;

  overflow: hidden;
}
/* 半圆顶 */
.head_top::after{
  bottom: 0;
  content: '';  
  width: 140%;
  height: 250rpx;
  position: absolute;
  z-index: -1;
  left: -20%;
  top: 0;
  border-radius: 0 0 50% 50%;
  background: #3a3a3a;
}




